{
  "name": "vs-chrome",
  "displayName": "Visual Studio Chrome",
  "description": "Browser Integration in Visual Studio Code",
  "version": "1.0.0",
  "publisher": "developer",
  "engines": { "vscode": "^1.80.0" },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vs-chrome-sidebar",
          "title": "VS-Chrome",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "vs-chrome-sidebar": [
        {
          "type": "webview",
          "id": "vs-chrome.view",
          "name": "Browser"
        }
      ]
    },
    "commands": [
      {
        "command": "vs-chrome.clearHistory",
        "title": "Clear Browser History",
        "icon": "$(trash)"
      },
      {
        "command": "vs-chrome.refresh",
        "title": "Refresh Browser",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "vs-chrome.refresh",
          "when": "view == vs-chrome.view",
          "group": "navigation"
        },
        {
          "command": "vs-chrome.clearHistory",
          "when": "view == vs-chrome.view"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0"
  }
}